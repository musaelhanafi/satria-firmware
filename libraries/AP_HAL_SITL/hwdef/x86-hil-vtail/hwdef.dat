# x86-hil-vtail: SITL board for HIL with X-Plane on x86/laptop, V-tail airframe.
# CH1=aileron, CH2=right ruddervator, CH3=throttle, CH4=left ruddervator.
# ArduPlane mixes elevator+rudder into CH2/CH4 via VTAIL_OUTPUT before output.
include ../sitl/hwdef.dat

define XPLANE_JSON "xplane_vtail.json"
